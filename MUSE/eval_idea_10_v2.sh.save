# define variable
port=18765
model_family="phi"
split="forget10"
minus_values=(5.0)

# Set my model paths here
model_path="../checkpoint_updated/MUSE/final_ft_noLORA_5_epochs_inst_lr1e-05_phi_full_minus_forget10_seed42_1"
pretrained_path="../checkpoint_updated/MUSE/final_ft_noLORA_5_epochs_inst_lr1e-05_phi_full_seed42_1"

for minus in "${minus_values[@]}"; do
    echo "Processing minus value: $minus"

    CUDA_VISIBLE_DEVICES=0 torchrun --nproc_per_node=1 --master_port=$port evaluate_util.py \
        model_family=$model_family \
        batch_size=100 \
        split=$split \
        model_path=$model_path \
        +minus_value=$minus \
        +pretrained_path=$pretrained_path \
        --config-name=eval_idea.yaml
done
